# Server listening port
PORT=5000

# Bind to all interfaces for cloud hosting
HOST=0.0.0.0

# Single frontend origin (used if FRONTEND_URLS is not set)
FRONTEND_URL=http://localhost:5173

# Optional: comma-separated frontend origins (for branch previews + production)
# FRONTEND_URLS=https://main.example.com,https://preview.example.com
